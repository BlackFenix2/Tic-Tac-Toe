{
  "name": "tic-tac-toe-react",
  "version": "0.2.3",
  "description": "Tic-Tac-Toe game for React",
  "scripts": {
    "dev": "vite",
    "build": "cross-env GITHUB_PAGES=true vite build",
    "build:local": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test:unit": "vitest run",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BlackFenix2/Tic-Tac-Toe.git"
  },
  "keywords": [
    "Game"
  ],
  "author": "Ernie Francis IV",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/BlackFenix2/Tic-Tac-Toe/issues"
  },
  "homepage": "https://github.com/BlackFenix2/Tic-Tac-Toe#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.5.9",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.5",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "cross-env": "^5.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
