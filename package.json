{
  "name": "tic-tac-toe-react",
  "version": "0.2.3",
  "description": "Tic-Tac-Toe game for React",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test:unit": "vitest run",
    "test": "playwright test && vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BlackFenix2/Tic-Tac-Toe.git"
  },
  "keywords": [
    "Game"
  ],
  "author": "Ernie Francis IV",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/BlackFenix2/Tic-Tac-Toe/issues"
  },
  "homepage": "https://github.com/BlackFenix2/Tic-Tac-Toe#readme",
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
